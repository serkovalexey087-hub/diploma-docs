      <bpmn:textAnnotation id="TextAnnotation_1w0smiq">
        <bpmn:text>Сотрудник ПЦ. УПР</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_1h06g14" associationDirection="None" sourceRef="Activity_10syc4f" targetRef="TextAnnotation_1w0smiq" />
      <bpmn:textAnnotation id="TextAnnotation_0h39hby">
        <bpmn:text>Сотрудник ДП</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_1jldmlk" associationDirection="None" sourceRef="Activity_1r5omcl" targetRef="TextAnnotation_0h39hby" />
      <bpmn:textAnnotation id="TextAnnotation_0waepyn">
        <bpmn:text>Сотрудник ДП</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_1q19bed" associationDirection="None" sourceRef="Activity_06ru3qu" targetRef="TextAnnotation_0waepyn" />
      <bpmn:textAnnotation id="TextAnnotation_1h6xton">
        <bpmn:text>Сотрудник ДП, Сотрудник ПЦ</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_0wclpjy" associationDirection="None" sourceRef="Activity_0wp0gmv" targetRef="TextAnnotation_1h6xton" />
      <bpmn:textAnnotation id="TextAnnotation_0bea5y8">
        <bpmn:text>Сотрудник ДМ, ДРПС</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_0ztire7" associationDirection="None" sourceRef="Activity_0khaado" targetRef="TextAnnotation_0bea5y8" />
      <bpmn:textAnnotation id="TextAnnotation_0gfijmb">
        <bpmn:text>Есть сегмент потенциальных заказчиков со схожими частотными и важными бизнес-задачами, для решения которых продукт гипотетически является более эффективным, а также наличие разумных возможностей и инструментов для продвижения продукта заказчику (в т.ч. партнерский канал)</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_1p0fa3n" associationDirection="None" sourceRef="DataObjectReference_1g8mauj" targetRef="TextAnnotation_0gfijmb" />
      <bpmn:textAnnotation id="TextAnnotation_16agj6b">
        <bpmn:text>Сотрудники ДП</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_17481ff" associationDirection="None" sourceRef="Activity_1vxjcvs" targetRef="TextAnnotation_16agj6b" />
      <bpmn:textAnnotation id="TextAnnotation_06wvwtf">
        <bpmn:text>Сотрудник ПЦ</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_11fz2c7" associationDirection="None" sourceRef="Activity_0gdn6cj" targetRef="TextAnnotation_06wvwtf" />
      <bpmn:textAnnotation id="TextAnnotation_1y77b6n">
        <bpmn:text>Внутренняя экспертиза с учетом клиентского опыта</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_0l7xwfj" associationDirection="None" sourceRef="Activity_0wp0gmv" targetRef="TextAnnotation_1y77b6n" />
      <bpmn:textAnnotation id="TextAnnotation_16elema">
        <bpmn:text>Необходимы Методические  рекомендации (проект)</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_1p4j0sc" associationDirection="None" sourceRef="Activity_10syc4f" targetRef="TextAnnotation_16elema" />
      <bpmn:textAnnotation id="TextAnnotation_1gzso7i">
        <bpmn:text>Отсечение заведомо непроходных сегментов/ Заказчиков</bpmn:text>
      </bpmn:textAnnotation>
      <bpmn:association id="Association_1g7efig" associationDirection="None" sourceRef="Activity_1r5omcl" targetRef="TextAnnotation_1gzso7i" />
